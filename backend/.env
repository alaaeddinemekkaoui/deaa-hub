DATABASE_URL="postgresql://postgres:admin1234@localhost:5432/deaa_hub?schema=public"
JWT_SECRET="change-this-super-secret"
JWT_EXPIRES_IN="1d"
# For local development - allows all origins
FRONTEND_URL="*"
# For LAN access, you can specify multiple URLs separated by commas
FRONTEND_URLS="*"
PORT=5000
# Force Prisma to use direct PostgreSQL connection instead of Data Proxy
PRISMA_CLIENT_ENGINE_TYPE="library"
