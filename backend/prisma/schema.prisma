  questions      OnlineExamQuestion[]
  attempts       OnlineExamAttempt[]

  @@index([academicYear])
  @@index([semester])
  @@index([moduleId])
  @@index([classId])
  @@index([filiereId])
  @@index([departmentId])
  @@index([createdById])
  @@index([status])
}

model OnlineExamQuestion {
  id             Int          @id @default(autoincrement())
  examId         Int
  type           QuestionType @default(mcq)
  prompt         String
  options        Json?
  correctAnswer  Json?
  points         Float        @default(1)
  orderIndex     Int          @default(0)
