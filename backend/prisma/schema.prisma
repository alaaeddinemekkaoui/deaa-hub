  sourcePlanId     Int?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  cycle            Cycle?                         @relation(fields: [cycleId], references: [id])
  filiere          Filiere?                       @relation(fields: [filiereId], references: [id])
  option           Option?                        @relation(fields: [optionId], references: [id])
  sourcePlan       AccreditationPlan?             @relation("AccreditationPlanSource", fields: [sourcePlanId], references: [id])
  derivedPlans     AccreditationPlan[]            @relation("AccreditationPlanSource")
  lines            AccreditationPlanLine[]
  classAssignments ClassAccreditationAssignment[]

  @@unique([name, academicYear])
  @@index([academicYear])
  @@index([filiereId])
  @@index([optionId])
  @@index([cycleId])
  @@index([status])
  @@index([sourcePlanId])
}

model AccreditationPlanLine {
  id            Int                     @id @default(autoincrement())
  planId        Int
  coursId       Int
  moduleId      Int?
  elementId     Int?
