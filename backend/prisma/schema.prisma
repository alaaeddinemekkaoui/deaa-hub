generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                  @id @default(autoincrement())
  fullName              String
  email                 String               @unique
  passwordHash          String
  role                  UserRole
  linkedInUrl           String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  activityLogs          ActivityLog[]
  receivedMessages      Message[]            @relation("ReceivedMessages")
  sentMessages          Message[]            @relation("SentMessages")
  groupMemberships      MessageGroupMember[]
  notifications         Notification[]
  approvedReservations  RoomReservation[]    @relation("ApprovedReservations")
  requestedReservations RoomReservation[]    @relation("RequestedReservations")
  coursResources        CoursResource[]
  mealReservationsMade  MealReservation[]    @relation("MealReservationsMade")
  mealTransactions      MealTransaction[]    @relation("MealTransactionsActor")
  studentProfile        Student?
  teacherProfile        Teacher?
  departments           UserDepartment[]
  assignedWorkflows     WorkflowTask[]
  validatedAttendances  AttendanceRecord[]   @relation("AttendanceValidatedBy")
  responsibleModules    Module[]             @relation("ModuleResponsable")
  housingReviews        HousingRequest[]     @relation("HousingRequestReviewer")
  housingStatusChanges  HousingStatusHistory[] @relation("HousingStatusChangedBy")
  documentApprovals     DocumentRequest[]    @relation("DocumentRequestApprover")
  documentGenerations   DocumentGeneration[] @relation("DocumentGenerationActor")
  apesaChoiceReviews    ApesaStudentChoice[] @relation("ApesaChoiceReviewer")
  apesaAssignments      ApesaAssignment[]    @relation("ApesaAssignmentActor")
  onlineExamsCreated    OnlineExam[]         @relation("OnlineExamCreator")
  validationUpdates     ValidationParameter[] @relation("ValidationParameterUpdater")
}

model UserDepartment {
  userId       Int
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
}

model Department {
  id              Int                 @id @default(autoincrement())
  name            String              @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  filieres        Filiere[]
  filiereLinks    FiliereDepartment[]
  classes         AcademicClass[]
  options         Option[]
  rooms           Room[]
  teachers        Teacher[]
  userDepartments UserDepartment[]
  housingQuotas   HousingQuota[]
  validationParameters ValidationParameter[]
  apesaOrientations ApesaOrientation[]
  onlineExams     OnlineExam[]

  @@index([name])
}

model Filiere {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String              @unique
  departmentId       Int
  filiereType        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  classes            AcademicClass[]
  accreditationPlans AccreditationPlan[]
  department         Department          @relation(fields: [departmentId], references: [id])
  departmentLinks    FiliereDepartment[]
  modules            Module[]
  options            Option[]
  students           Student[]
  teachers           Teacher[]
  validationParameters ValidationParameter[]
  apesaOrientations ApesaOrientation[]
  onlineExams        OnlineExam[]

  @@index([departmentId])
}

model FiliereDepartment {
  id           Int        @id @default(autoincrement())
  filiereId    Int
  departmentId Int
  createdAt    DateTime   @default(now())
  filiere      Filiere    @relation(fields: [filiereId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([filiereId, departmentId])
  @@index([filiereId])
  @@index([departmentId])
}

model Student {
  id                 Int                   @id @default(autoincrement())
  firstName          String?
  lastName           String?
  fullName           String
  sex                Sex
  cin                String                @unique
  codeMassar         String                @unique
  dateNaissance      DateTime
  email              String?               @unique
  telephone          String?
  linkedInUrl        String?
  cycle              StudentCycle
  prepaYear          PrepaYear?
  prepaTrack         String?
  entryLevel         Int?
  filiereId          Int?
  classId            Int?
  bacType            String?
  firstYearEntry     Int
  anneeAcademique    String
  dateInscription    DateTime              @default(now())
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  codeEtudiant       String?               @unique
  userId             Int?                  @unique
  documents          Document[]
  laureate           Laureate?
  academicClass      AcademicClass?        @relation(fields: [classId], references: [id])
  filiere            Filiere?              @relation(fields: [filiereId], references: [id])
  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  classHistory       StudentClassHistory[]
  grades             StudentGrade[]
  mealReservations   MealReservation[]
  mealTransactions   MealTransaction[]
  mealWallet         MealWallet?
  internatAssignment InternatAssignment?
  observations       StudentObservation[]
  workflows          WorkflowTask[]
  attendances        AttendanceRecord[]
  housingRequests    HousingRequest[]
  documentRequests   DocumentRequest[]
  academicEvents     StudentAcademicEvent[]
  apesaChoices       ApesaStudentChoice[]
  apesaAssignments   ApesaAssignment[]
  examAttempts       OnlineExamAttempt[]

  photoPath String?

  @@index([codeMassar])
  @@index([filiereId])
  @@index([classId])
  @@index([classId, fullName])
  @@index([cycle])
  @@index([sex])
  @@index([firstYearEntry])
}

model StudentObservation {
  id        Int      @id @default(autoincrement())
  studentId Int
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model StudentClassHistory {
  id             Int           @id @default(autoincrement())
  studentId      Int
  classId        Int
  academicYear   String
  studyYear      Int
  decisionStatus String?       @default("admis")
  createdAt      DateTime      @default(now())
  semestre       String?
  academicClass  AcademicClass @relation(fields: [classId], references: [id])
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYear])
  @@index([studentId])
  @@index([classId])
  @@index([academicYear])
}

model Teacher {
  id              Int                @id @default(autoincrement())
  firstName       String
  lastName        String
  sex             Sex                @default(male)
  cin             String?            @unique
  email           String?            @unique
  phoneNumber     String?
  linkedInUrl     String?
  dateInscription DateTime           @default(now())
  departmentId    Int
  filiereId       Int?
  roleId          Int
  gradeId         Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  userId          Int?               @unique
  taughtCours     CoursClass[]
  documents       Document[]
  coursResources  CoursResource[]
  recordedGrades  StudentGrade[]
  department      Department         @relation(fields: [departmentId], references: [id])
  filiere         Filiere?           @relation(fields: [filiereId], references: [id])
  grade           TeacherGrade       @relation(fields: [gradeId], references: [id])
  role            TeacherRole        @relation(fields: [roleId], references: [id])
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  taughtClasses   TeacherClass[]
  sessions        TimetableSession[]
  workloads       TeacherWorkload[]

  photoPath String?

  @@index([departmentId])
  @@index([filiereId])
  @@index([sex])
  @@index([roleId])
  @@index([gradeId])
  @@index([lastName, firstName])
}

model TeacherRole {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]
}

model TeacherGrade {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]
}

model Cycle {
  id                 Int                 @id @default(autoincrement())
  name               String              @unique
  code               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  classes            AcademicClass[]
  accreditationPlans AccreditationPlan[]
}

model AcademicYear {
  id                Int                    @id @default(autoincrement())
  label             String                 @unique
  startYear         Int?
  endYear           Int?
  isCurrent         Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  cursusAssignments CursusYearAssignment[]

  @@index([isCurrent])
  @@index([startYear])
  @@index([endYear])
}

model AcademicClass {
  id                           Int                            @id @default(autoincrement())
  name                         String
  year                         Int
  academicYear                 String?
  semestre                     String?
  departmentId                 Int?
  filiereId                    Int?
  classType                    String?
  cycleId                      Int?
  option                       String?
  optionId                     Int?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  cycle                        Cycle?                         @relation(fields: [cycleId], references: [id])
  department                   Department?                    @relation(fields: [departmentId], references: [id])
  filiere                      Filiere?                       @relation(fields: [filiereId], references: [id])
  academicOption               Option?                        @relation(fields: [optionId], references: [id])
  groups                       ClassGroup[]
  cursuses                     Cursus[]
  cursusAssignments            CursusYearAssignment[]
  ClassAccreditationAssignment ClassAccreditationAssignment[]
  cours                        CoursClass[]
  elements                     ElementModule[]
  modules                      ModuleClass[]
  reservations                 RoomReservation[]
  coursResources               CoursResource[]
  students                     Student[]
  studentHistory               StudentClassHistory[]
  grades                       StudentGrade[]
  teachers                     TeacherClass[]
  sessions                     TimetableSession[]
  onlineExams                  OnlineExam[]

  @@unique([name, year, semestre, academicYear])
  @@index([year])
  @@index([academicYear])
  @@index([semestre])
  @@index([departmentId])
  @@index([filiereId])
  @@index([optionId])
  @@index([cycleId])
}

model ClassGroup {
  id                Int                     @id @default(autoincrement())
  classId           Int
  name              String
  type              String                  @default("TD")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  class             AcademicClass           @relation(fields: [classId], references: [id], onDelete: Cascade)
  timetableSessions TimetableSessionGroup[]

  @@unique([classId, name])
  @@index([classId])
  @@index([type])
}

model Cursus {
  id              Int                    @id @default(autoincrement())
  name            String
  classId         Int?
  version         Int                    @default(1)
  isActive        Boolean                @default(true)
  clonedFromId    Int?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  class           AcademicClass?         @relation(fields: [classId], references: [id], onDelete: SetNull)
  clonedFrom      Cursus?                @relation("CursusClone", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones          Cursus[]               @relation("CursusClone")
  yearAssignments CursusYearAssignment[]
  modules         Module[]

  @@index([classId])
  @@index([isActive])
  @@index([clonedFromId])
}

model CursusYearAssignment {
  id             Int           @id @default(autoincrement())
  classId        Int
  academicYearId Int
  cursusId       Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  class          AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  cursus         Cursus        @relation(fields: [cursusId], references: [id], onDelete: Cascade)

  @@unique([classId, academicYearId])
  @@index([classId])
  @@index([academicYearId])
  @@index([cursusId])
}

model ModuleClass {
  moduleId Int
  classId  Int
  class    AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  module   Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([moduleId, classId])
  @@index([moduleId])
  @@index([classId])
}

model TeacherClass {
  id        Int           @id @default(autoincrement())
  teacherId Int
  classId   Int
  createdAt DateTime      @default(now())
  class     AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
  @@index([teacherId])
  @@index([classId])
}

model Document {
  id              Int        @id @default(autoincrement())
  name            String
  mimeType        String
  path            String
  storageProvider String?    @default("local")
  bucket          String?
  objectKey       String?
  fileHash        String?
  size            Int?
  studentId       Int?
  teacherId       Int?
  category        String?
  createdAt       DateTime   @default(now())
  student         Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher         Teacher?   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  laureateProof   Laureate[]
  generatedForRequest DocumentRequest? @relation("GeneratedDocumentForRequest")

  @@index([studentId])
  @@index([teacherId])
  @@index([storageProvider])
  @@index([bucket, objectKey])
}

model DocumentTemplate {
  id                          Int           @id @default(autoincrement())
  name                        String        @unique
  type                        String        @default("releve_note")
  documentTypeId              Int?          @unique
  header                      String
  body                        String
  footer                      String?
  primaryColor                String?       @default("#0f766e")
  signatureLabel              String?       @default("Direction des Affaires Académiques")
  eSignatureEnabled           Boolean       @default(true)
  eSignatureSignerName        String?       @default("DEAA Hub")
  eSignatureSignerTitle       String?       @default("Direction des Affaires Académiques")
  eSignatureStampText         String?       @default("Signé électroniquement")
  eSignaturePositionX         Float         @default(0.62)
  eSignaturePositionY         Float         @default(0.82)
  eSignatureWidth             Float         @default(0.24)
  eSignatureHeight            Float         @default(0.08)
  docxTemplatePath            String?
  docxTemplateName            String?
  docxTemplateMimeType        String?
  docxTemplateStorageProvider String?
  docxTemplateBucket          String?
  docxTemplateObjectKey       String?
  docxTemplateFileHash        String?
  docxTemplateSize            Int?
  isDefault                   Boolean       @default(false)
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  documentType                DocumentType? @relation(fields: [documentTypeId], references: [id], onDelete: SetNull)
  generations                 DocumentGeneration[]

  @@index([type])
  @@index([isDefault])
  @@index([documentTypeId])
}

model ESignatureAsset {
  id              Int      @id @default(autoincrement())
  name            String   @default("Signature officielle")
  mimeType        String
  path            String
  storageProvider String?  @default("minio")
  bucket          String?
  objectKey       String?
  fileHash        String?
  size            Int?
  active          Boolean  @default(true)
  uploadedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active])
  @@index([uploadedAt])
}

model StudentGrade {
  id                 Int            @id @default(autoincrement())
  studentId          Int
  teacherId          Int?
  classId            Int?
  moduleId           Int?
  elementModuleId    Int?
  subject            String
  semester           String?
  assessmentType     String?
  score              Float
  maxScore           Float          @default(20)
  rattrapageScore    Float?
  rattrapageMaxScore Float?
  academicYear       String
  publicationStatus  String         @default("draft")
  publishedAt        DateTime?
  reopenedAt         DateTime?
  lockedAt           DateTime?
  comment            String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  academicClass      AcademicClass? @relation(fields: [classId], references: [id])
  elementModule      ElementModule? @relation(fields: [elementModuleId], references: [id])
  module             Module?        @relation(fields: [moduleId], references: [id])
  student            Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher            Teacher?       @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@index([classId])
  @@index([moduleId])
  @@index([elementModuleId])
  @@index([academicYear])
  @@index([publicationStatus])
  @@index([subject])
  @@index([studentId, academicYear], map: "idx_grade_student_year")
  @@index([classId, academicYear, semester], map: "idx_grade_class_year_sem")
  @@index([classId, moduleId, elementModuleId, academicYear, semester], map: "idx_grade_lookup_base")
  @@index([classId, moduleId, elementModuleId, academicYear, semester, assessmentType], map: "idx_grade_lookup_assessment")
}

model DocumentType {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  template    DocumentTemplate?
  workflows   WorkflowTask[]
  requests    DocumentRequest[]
}

model ProfileDocumentType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkflowTask {
  id             Int                @id @default(autoincrement())
  title          String
  description    String?
  status         WorkflowStatus     @default(pending)
  assignedToId   Int
  studentId      Int?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  documentTypeId Int?
  assignedTo     User               @relation(fields: [assignedToId], references: [id])
  documentType   DocumentType?      @relation(fields: [documentTypeId], references: [id])
  student        Student?           @relation(fields: [studentId], references: [id])
  timeline       WorkflowTimeline[]

  @@index([assignedToId])
  @@index([studentId])
  @@index([documentTypeId])
}

model WorkflowTimeline {
  id        Int            @id @default(autoincrement())
  taskId    Int
  status    WorkflowStatus
  note      String?
  changedAt DateTime       @default(now())
  task      WorkflowTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model MessageGroup {
  id          Int                  @id @default(autoincrement())
  name        String
  type        GroupType
  referenceId Int?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  messages    Message[]
  members     MessageGroupMember[]

  @@index([type])
  @@index([referenceId])
}

model MessageGroupMember {
  groupId Int
  userId  Int
  canSend Boolean      @default(false)
  group   MessageGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

model Message {
  id            Int            @id @default(autoincrement())
  senderId      Int
  content       String
  fileUrl       String?
  createdAt     DateTime       @default(now())
  recipientId   Int?
  groupId       Int?
  group         MessageGroup?  @relation(fields: [groupId], references: [id])
  recipient     User?          @relation("ReceivedMessages", fields: [recipientId], references: [id])
  sender        User           @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([senderId])
  @@index([recipientId])
  @@index([groupId])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  messageId Int?
  type      String   @default("message")
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  message   Message? @relation(fields: [messageId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Room {
  id           Int                @id @default(autoincrement())
  name         String             @unique
  departmentId Int?
  capacity     Int
  equipment    Json?
  availability Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  department   Department?        @relation(fields: [departmentId], references: [id])
  reservations RoomReservation[]
  sessions     TimetableSession[]

  @@index([departmentId])
}

model InternatRoom {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  capacity    Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  assignments InternatAssignment[]
}

model InternatAssignment {
  id        Int          @id @default(autoincrement())
  studentId Int          @unique
  roomId    Int
  comment   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  room      InternatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model RoomReservation {
  id            Int                    @id @default(autoincrement())
  roomId        Int
  classId       Int?
  date          String
  dayOfWeek     Int
  startTime     String
  endTime       String
  reservedBy    String
  purpose       RoomReservationPurpose @default(cours)
  notes         String?
  status        ReservationStatus      @default(pending)
  requestedById Int?
  approvedById  Int?
  approvalNote  String?
  approvedAt    DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  approvedBy    User?                  @relation("ApprovedReservations", fields: [approvedById], references: [id])
  academicClass AcademicClass?         @relation(fields: [classId], references: [id])
  requestedBy   User?                  @relation("RequestedReservations", fields: [requestedById], references: [id])
  room          Room                   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([classId])
  @@index([date])
  @@index([dayOfWeek])
  @@index([roomId, date])
  @@index([status])
  @@index([requestedById])
}

model Laureate {
  id              Int           @id @default(autoincrement())
  studentId       Int           @unique
  graduationYear  Int
  diplomaStatus   DiplomaStatus @default(not_retrieved)
  proofDocumentId Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  proofDocument   Document?     @relation(fields: [proofDocumentId], references: [id])
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([graduationYear])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  metadata  Json?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Cours {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @unique
  type                  ElementType             @default(CM)
  elementModuleId       Int?                    @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  AccreditationPlanLine AccreditationPlanLine[]
  elementModule         ElementModule?          @relation(fields: [elementModuleId], references: [id])
  classes               CoursClass[]
  resources             CoursResource[]
  attendanceRecords     AttendanceRecord[]
  workloads             CourseWorkload[]

  @@index([name])
  @@index([elementModuleId])
}

model Option {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String?
  filiereId          Int
  departmentId       Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  classes            AcademicClass[]
  accreditationPlans AccreditationPlan[]
  modules            Module[]
  department         Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  filiere            Filiere             @relation(fields: [filiereId], references: [id])

  @@unique([name, filiereId, departmentId])
  @@index([filiereId])
  @@index([departmentId])
}

model Module {
  id                    Int                     @id @default(autoincrement())
  name                  String
  semestre              String?
  cursusId              Int?
  filiereId             Int?
  optionId              Int?
  responsableId         Int?
  coefficient           Float                   @default(1)
  credits               Float                   @default(0)
  volumeHoraire         Int?
  cmHours               Int                     @default(0)
  tdHours               Int                     @default(0)
  tpHours               Int                     @default(0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  AccreditationPlanLine AccreditationPlanLine[]
  cursus                Cursus?                 @relation(fields: [cursusId], references: [id], onDelete: SetNull)
  elements              ElementModule[]
  filiere               Filiere?                @relation(fields: [filiereId], references: [id])
  option                Option?                 @relation(fields: [optionId], references: [id])
  responsable           User?                   @relation("ModuleResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  classes               ModuleClass[]
  grades                StudentGrade[]
  onlineExams           OnlineExam[]

  @@index([cursusId])
  @@index([filiereId])
  @@index([optionId])
  @@index([responsableId])
