  reservation   MealReservation?    @relation(fields: [reservationId], references: [id])
  student       Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([actorUserId])
  @@index([reservationId])
  @@index([createdAt])
}

model AccreditationPlan {
  id               Int                            @id @default(autoincrement())
  name             String
  academicYear     String
  levelYear        Int?
  filiereId        Int?
  optionId         Int?
  cycleId          Int?
