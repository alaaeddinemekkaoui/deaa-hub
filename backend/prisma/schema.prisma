  @@index([coursId])
  @@index([classId])
  @@index([coursId, classId])
  @@index([teacherId])
}

model CoursResource {
  id              Int           @id @default(autoincrement())
  coursId         Int
  classId         Int
  teacherId       Int?
  uploadedById    Int
