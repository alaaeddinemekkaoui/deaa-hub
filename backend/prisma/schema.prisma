model OnlineExam {
  id             Int              @id @default(autoincrement())
  title          String
  description    String?
  academicYear   String
  semester       String?
  moduleId       Int?
  classId        Int?
  filiereId      Int?
  departmentId   Int?
  createdById    Int
  startsAt       DateTime?
  endsAt         DateTime?
  durationMinutes Int?
  status         OnlineExamStatus @default(draft)
  randomizeQuestions Boolean      @default(false)
  antiCheatEnabled Boolean        @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  module         Module?          @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  class          AcademicClass?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  filiere        Filiere?         @relation(fields: [filiereId], references: [id], onDelete: SetNull)
  department     Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
