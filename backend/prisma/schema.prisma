  room                Room?                   @relation(fields: [roomId], references: [id])
  teacher             Teacher?                @relation(fields: [teacherId], references: [id])
  attendanceRecords   AttendanceRecord[]
  groupAssignments    TimetableSessionGroup[]

  @@index([classId])
  @@index([teacherId])
  @@index([roomId])
  @@index([elementId])
  @@index([dayOfWeek])
  @@index([weekStart])
  @@index([attendanceEnabled])
  @@index([attendanceDeadline])
}

model TimetableSessionGroup {
  sessionId Int
  groupId   Int
  session   TimetableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  group     ClassGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([sessionId, groupId])
  @@index([groupId])
}

model TimetableHoliday {
  id          Int      @id @default(autoincrement())
  date        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

