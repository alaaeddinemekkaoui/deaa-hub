generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                  @id @default(autoincrement())
  fullName              String
  email                 String               @unique
  passwordHash          String
  role                  UserRole
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  activityLogs          ActivityLog[]
  receivedMessages      Message[]            @relation("ReceivedMessages")
  sentMessages          Message[]            @relation("SentMessages")
  groupMemberships      MessageGroupMember[]
  notifications         Notification[]
  approvedReservations  RoomReservation[]    @relation("ApprovedReservations")
  requestedReservations RoomReservation[]    @relation("RequestedReservations")
  coursResources        CoursResource[]
  mealReservationsMade  MealReservation[]    @relation("MealReservationsMade")
  mealTransactions      MealTransaction[]    @relation("MealTransactionsActor")
  studentProfile        Student?
  teacherProfile        Teacher?
  departments           UserDepartment[]
  assignedWorkflows     WorkflowTask[]
  validatedAttendances  AttendanceRecord[]   @relation("AttendanceValidatedBy")
}

model UserDepartment {
  userId       Int
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
}

model Department {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  filieres        Filiere[]
  rooms           Room[]
  teachers        Teacher[]
  userDepartments UserDepartment[]

  @@index([name])
}

model Filiere {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String              @unique
  departmentId       Int
  filiereType        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  classes            AcademicClass[]
  accreditationPlans AccreditationPlan[]
  department         Department          @relation(fields: [departmentId], references: [id])
  modules            Module[]
  options            Option[]
  students           Student[]
  teachers           Teacher[]

  @@index([departmentId])
}

model Student {
  id               Int                   @id @default(autoincrement())
  firstName        String?
  lastName         String?
  fullName         String
  sex              Sex
  cin              String                @unique
  codeMassar       String                @unique
  dateNaissance    DateTime
  email            String?               @unique
  telephone        String?
  cycle            StudentCycle
  prepaYear        PrepaYear?
  prepaTrack       String?
  entryLevel       Int?
  filiereId        Int?
  classId          Int?
  bacType          String?
  firstYearEntry   Int
  anneeAcademique  String
  dateInscription  DateTime              @default(now())
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  codeEtudiant     String?               @unique
  userId           Int?                  @unique
  documents        Document[]
  laureate         Laureate?
  academicClass    AcademicClass?        @relation(fields: [classId], references: [id])
  filiere          Filiere?              @relation(fields: [filiereId], references: [id])
  user             User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  classHistory     StudentClassHistory[]
  grades           StudentGrade[]
  mealReservations MealReservation[]
  mealTransactions MealTransaction[]
  mealWallet       MealWallet?
  internatAssignment InternatAssignment?
  observations     StudentObservation[]
  workflows        WorkflowTask[]
  attendances      AttendanceRecord[]

  photoPath        String?

  @@index([codeMassar])
  @@index([filiereId])
  @@index([classId])
  @@index([classId, fullName])
  @@index([cycle])
  @@index([sex])
  @@index([firstYearEntry])
}

model StudentObservation {
  id        Int      @id @default(autoincrement())
  studentId Int
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model StudentClassHistory {
  id             Int           @id @default(autoincrement())
  studentId      Int
  classId        Int
  academicYear   String
  studyYear      Int
  decisionStatus String?       @default("admis")
  createdAt      DateTime      @default(now())
  semestre       String?
  academicClass  AcademicClass @relation(fields: [classId], references: [id])
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYear])
  @@index([studentId])
  @@index([classId])
  @@index([academicYear])
}

model Teacher {
  id              Int                @id @default(autoincrement())
  firstName       String
  lastName        String
  sex             Sex                @default(male)
  cin             String?            @unique
  email           String?            @unique
  phoneNumber     String?
  dateInscription DateTime           @default(now())
  departmentId    Int
  filiereId       Int?
  roleId          Int
  gradeId         Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  userId          Int?               @unique
  taughtCours     CoursClass[]
  documents       Document[]
  coursResources  CoursResource[]
  recordedGrades  StudentGrade[]
  department      Department         @relation(fields: [departmentId], references: [id])
  filiere         Filiere?           @relation(fields: [filiereId], references: [id])
  grade           TeacherGrade       @relation(fields: [gradeId], references: [id])
  role            TeacherRole        @relation(fields: [roleId], references: [id])
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  taughtClasses   TeacherClass[]
  sessions        TimetableSession[]

  photoPath       String?

  @@index([departmentId])
  @@index([filiereId])
  @@index([sex])
  @@index([roleId])
  @@index([gradeId])
  @@index([lastName, firstName])
}

model TeacherRole {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]
}

model TeacherGrade {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]
}

model Cycle {
  id                 Int                 @id @default(autoincrement())
  name               String              @unique
  code               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  classes            AcademicClass[]
  accreditationPlans AccreditationPlan[]
}

model AcademicYear {
  id        Int      @id @default(autoincrement())
  label     String   @unique
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isCurrent])
}

model AcademicClass {
  id                           Int                            @id @default(autoincrement())
  name                         String
  year                         Int
  academicYear                 String?
  semestre                     String?
  filiereId                    Int?
  classType                    String?
  cycleId                      Int?
  option                       String?
  optionId                     Int?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  cycle                        Cycle?                         @relation(fields: [cycleId], references: [id])
  filiere                      Filiere?                       @relation(fields: [filiereId], references: [id])
  academicOption               Option?                        @relation(fields: [optionId], references: [id])
  ClassAccreditationAssignment ClassAccreditationAssignment[]
  cours                        CoursClass[]
  elements                     ElementModule[]
  modules                      ModuleClass[]
  reservations                 RoomReservation[]
  coursResources               CoursResource[]
  students                     Student[]
  studentHistory               StudentClassHistory[]
  grades                       StudentGrade[]
  teachers                     TeacherClass[]
  sessions                     TimetableSession[]

  @@unique([name, year, semestre, academicYear])
  @@index([year])
  @@index([academicYear])
  @@index([semestre])
  @@index([filiereId])
  @@index([optionId])
  @@index([cycleId])
}

model ModuleClass {
  moduleId Int
  classId  Int
  class    AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  module   Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([moduleId, classId])
  @@index([moduleId])
  @@index([classId])
}

model TeacherClass {
  id        Int           @id @default(autoincrement())
  teacherId Int
  classId   Int
  createdAt DateTime      @default(now())
  class     AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
  @@index([teacherId])
  @@index([classId])
}

model Document {
  id            Int        @id @default(autoincrement())
  name          String
  mimeType      String
  path          String
  studentId     Int?
  teacherId     Int?
  category      String?
  createdAt     DateTime   @default(now())
  student       Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher       Teacher?   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  laureateProof Laureate[]

  @@index([studentId])
  @@index([teacherId])
}

model StudentGrade {
  id                 Int            @id @default(autoincrement())
  studentId          Int
  teacherId          Int?
  classId            Int?
  moduleId           Int?
  elementModuleId    Int?
  subject            String
  semester           String?
  assessmentType     String?
  score              Float
  maxScore           Float          @default(20)
  rattrapageScore    Float?
  rattrapageMaxScore Float?
  academicYear       String
  publicationStatus  String         @default("draft")
  publishedAt        DateTime?
  reopenedAt         DateTime?
  lockedAt           DateTime?
  comment            String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  academicClass      AcademicClass? @relation(fields: [classId], references: [id])
  elementModule      ElementModule? @relation(fields: [elementModuleId], references: [id])
  module             Module?        @relation(fields: [moduleId], references: [id])
  student            Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher            Teacher?       @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@index([classId])
  @@index([moduleId])
  @@index([elementModuleId])
  @@index([academicYear])
  @@index([publicationStatus])
  @@index([subject])
  @@index([studentId, academicYear], map: "idx_grade_student_year")
  @@index([classId, academicYear, semester], map: "idx_grade_class_year_sem")
  @@index([classId, moduleId, elementModuleId, academicYear, semester], map: "idx_grade_lookup_base")
  @@index([classId, moduleId, elementModuleId, academicYear, semester, assessmentType], map: "idx_grade_lookup_assessment")
}

model DocumentType {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workflows   WorkflowTask[]
}

model ProfileDocumentType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkflowTask {
  id             Int                @id @default(autoincrement())
  title          String
  description    String?
  status         WorkflowStatus     @default(pending)
  assignedToId   Int
  studentId      Int?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  documentTypeId Int?
  assignedTo     User               @relation(fields: [assignedToId], references: [id])
  documentType   DocumentType?      @relation(fields: [documentTypeId], references: [id])
  student        Student?           @relation(fields: [studentId], references: [id])
  timeline       WorkflowTimeline[]

  @@index([assignedToId])
  @@index([studentId])
  @@index([documentTypeId])
}

model WorkflowTimeline {
  id        Int            @id @default(autoincrement())
  taskId    Int
  status    WorkflowStatus
  note      String?
  changedAt DateTime       @default(now())
  task      WorkflowTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model MessageGroup {
  id          Int                  @id @default(autoincrement())
  name        String
  type        GroupType
  referenceId Int?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  messages    Message[]
  members     MessageGroupMember[]

  @@index([type])
  @@index([referenceId])
}

model MessageGroupMember {
  groupId Int
  userId  Int
  canSend Boolean      @default(false)
  group   MessageGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

model Message {
  id            Int            @id @default(autoincrement())
  senderId      Int
  content       String
  fileUrl       String?
  createdAt     DateTime       @default(now())
  recipientId   Int?
  groupId       Int?
  group         MessageGroup?  @relation(fields: [groupId], references: [id])
  recipient     User?          @relation("ReceivedMessages", fields: [recipientId], references: [id])
  sender        User           @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([senderId])
  @@index([recipientId])
  @@index([groupId])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  messageId Int?
  type      String   @default("message")
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  message   Message? @relation(fields: [messageId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Room {
  id           Int                @id @default(autoincrement())
  name         String             @unique
  departmentId Int?
  capacity     Int
  equipment    Json?
  availability Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  department   Department?        @relation(fields: [departmentId], references: [id])
  reservations RoomReservation[]
  sessions     TimetableSession[]

  @@index([departmentId])
}

model InternatRoom {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  capacity    Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  assignments InternatAssignment[]
}

model InternatAssignment {
  id        Int         @id @default(autoincrement())
  studentId Int         @unique
  roomId    Int
  comment   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  room      InternatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model RoomReservation {
  id            Int                    @id @default(autoincrement())
  roomId        Int
  classId       Int?
  date          String
  dayOfWeek     Int
  startTime     String
  endTime       String
  reservedBy    String
  purpose       RoomReservationPurpose @default(cours)
  notes         String?
  status        ReservationStatus      @default(pending)
  requestedById Int?
  approvedById  Int?
  approvalNote  String?
  approvedAt    DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  approvedBy    User?                  @relation("ApprovedReservations", fields: [approvedById], references: [id])
  academicClass AcademicClass?         @relation(fields: [classId], references: [id])
  requestedBy   User?                  @relation("RequestedReservations", fields: [requestedById], references: [id])
  room          Room                   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([classId])
  @@index([date])
  @@index([dayOfWeek])
  @@index([roomId, date])
  @@index([status])
  @@index([requestedById])
}

model Laureate {
  id              Int           @id @default(autoincrement())
  studentId       Int           @unique
  graduationYear  Int
  diplomaStatus   DiplomaStatus @default(not_retrieved)
  proofDocumentId Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  proofDocument   Document?     @relation(fields: [proofDocumentId], references: [id])
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([graduationYear])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  metadata  Json?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Cours {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @unique
  type                  ElementType             @default(CM)
  elementModuleId       Int?                    @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  AccreditationPlanLine AccreditationPlanLine[]
  elementModule         ElementModule?          @relation(fields: [elementModuleId], references: [id])
  classes               CoursClass[]
  resources             CoursResource[]
  attendanceRecords     AttendanceRecord[]

  @@index([name])
  @@index([elementModuleId])
}

model Option {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String?
  filiereId          Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  classes            AcademicClass[]
  accreditationPlans AccreditationPlan[]
  modules            Module[]
  filiere            Filiere             @relation(fields: [filiereId], references: [id])

  @@unique([name, filiereId])
  @@index([filiereId])
}

model Module {
  id                    Int                     @id @default(autoincrement())
  name                  String
  semestre              String?
  filiereId             Int?
  optionId              Int?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  AccreditationPlanLine AccreditationPlanLine[]
  elements              ElementModule[]
  filiere               Filiere?                @relation(fields: [filiereId], references: [id])
  option                Option?                 @relation(fields: [optionId], references: [id])
  classes               ModuleClass[]
  grades                StudentGrade[]

  @@index([filiereId])
  @@index([optionId])
}

model ElementModule {
  id                    Int                     @id @default(autoincrement())
  name                  String
  moduleId              Int
  classId               Int?
  volumeHoraire         Int?
  sessionDurationMinutes Int?
  type                  ElementType             @default(CM)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  ponderation           Float                   @default(1)
  coefficient           Float                   @default(1)
  AccreditationPlanLine AccreditationPlanLine[]
  cours                 Cours?
  class                 AcademicClass?          @relation(fields: [classId], references: [id])
  module                Module                  @relation(fields: [moduleId], references: [id])
  grades                StudentGrade[]
  sessions              TimetableSession[]

  @@index([moduleId])
  @@index([classId])
}

model TimetableSession {
  id        Int           @id @default(autoincrement())
  elementId Int
  classId   Int
  teacherId Int?
  roomId    Int?
  dayOfWeek Int
  startTime String
  endTime   String
  weekStart DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  attendanceEnabled Boolean @default(false)
  attendanceTokenHash String? @unique
  attendanceEnabledAt DateTime?
  attendanceDeadline DateTime?
  attendanceClosedAt DateTime?
  class     AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  element   ElementModule @relation(fields: [elementId], references: [id], onDelete: Cascade)
  room      Room?         @relation(fields: [roomId], references: [id])
  teacher   Teacher?      @relation(fields: [teacherId], references: [id])
  attendanceRecords AttendanceRecord[]

  @@index([classId])
  @@index([teacherId])
  @@index([roomId])
  @@index([elementId])
  @@index([dayOfWeek])
  @@index([weekStart])
  @@index([attendanceEnabled])
  @@index([attendanceDeadline])
}

model TimetableHoliday {
  id          Int      @id @default(autoincrement())
  date        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model AttendanceRecord {
  id            Int              @id @default(autoincrement())
  studentId     Int
  courseId      Int?
  sessionId     Int
  status        AttendanceStatus @default(pending)
  timestamp     DateTime?
  validatedById Int?
  method        AttendanceMethod @default(qr)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  course        Cours?           @relation(fields: [courseId], references: [id])
  session       TimetableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  validatedBy   User?            @relation("AttendanceValidatedBy", fields: [validatedById], references: [id])

  @@unique([studentId, sessionId])
  @@index([studentId])
  @@index([courseId])
  @@index([sessionId])
  @@index([status])
  @@index([timestamp])
}

model CoursClass {
  id         Int           @id @default(autoincrement())
  coursId    Int
  classId    Int
  teacherId  Int?
  groupLabel String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  class      AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  cours      Cours         @relation(fields: [coursId], references: [id], onDelete: Cascade)
  teacher    Teacher?      @relation(fields: [teacherId], references: [id])

  @@unique([coursId, classId, teacherId])
  @@index([coursId])
  @@index([classId])
  @@index([coursId, classId])
  @@index([teacherId])
}

model CoursResource {
  id           Int           @id @default(autoincrement())
  coursId      Int
  classId      Int
  teacherId    Int?
  uploadedById Int
  title        String
  fileName     String
  mimeType     String
  path         String
  size         Int
  createdAt    DateTime      @default(now())
  class        AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  cours        Cours         @relation(fields: [coursId], references: [id], onDelete: Cascade)
  teacher      Teacher?      @relation(fields: [teacherId], references: [id])
  uploadedBy   User          @relation(fields: [uploadedById], references: [id])

  @@index([coursId])
  @@index([classId])
  @@index([teacherId])
  @@index([uploadedById])
  @@index([createdAt])
}

model Meal {
  id           Int               @id @default(autoincrement())
  name         String
  price        Float
  active       Boolean           @default(true)
  serviceStartTime String?
  serviceEndTime   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  reservations MealReservation[]

  @@index([active])
}

model MealWallet {
  id        Int      @id @default(autoincrement())
  studentId Int      @unique
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model MealReservation {
  id              Int                   @id @default(autoincrement())
  mealId          Int
  studentId       Int
  reservedById    Int
  reservationDate String
  quantity        Int                   @default(1)
  totalPrice      Float
  status          MealReservationStatus @default(confirmed)
  receiptNumber   String                @unique
  ticketCode      String?               @unique
  ticketIssuedAt  DateTime?
  consumedAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  meal            Meal                  @relation(fields: [mealId], references: [id])
  reservedBy      User                  @relation("MealReservationsMade", fields: [reservedById], references: [id])
  student         Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transactions    MealTransaction[]

  @@index([mealId])
  @@index([studentId])
  @@index([reservedById])
  @@index([reservationDate])
  @@index([createdAt])
}

model MealTransaction {
  id            Int                 @id @default(autoincrement())
  studentId     Int
  actorUserId   Int
  reservationId Int?
  type          MealTransactionType
  amount        Float
  balanceAfter  Float
  description   String?
  createdAt     DateTime            @default(now())
  actor         User                @relation("MealTransactionsActor", fields: [actorUserId], references: [id])
  reservation   MealReservation?    @relation(fields: [reservationId], references: [id])
  student       Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([actorUserId])
  @@index([reservationId])
  @@index([createdAt])
}

model AccreditationPlan {
  id               Int                            @id @default(autoincrement())
  name             String
  academicYear     String
  levelYear        Int?
  filiereId        Int?
  optionId         Int?
  cycleId          Int?
  status           AccreditationPlanStatus        @default(draft)
  sourcePlanId     Int?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  cycle            Cycle?                         @relation(fields: [cycleId], references: [id])
  filiere          Filiere?                       @relation(fields: [filiereId], references: [id])
  option           Option?                        @relation(fields: [optionId], references: [id])
  sourcePlan       AccreditationPlan?             @relation("AccreditationPlanSource", fields: [sourcePlanId], references: [id])
  derivedPlans     AccreditationPlan[]            @relation("AccreditationPlanSource")
  lines            AccreditationPlanLine[]
  classAssignments ClassAccreditationAssignment[]

  @@unique([name, academicYear])
  @@index([academicYear])
  @@index([filiereId])
  @@index([optionId])
  @@index([cycleId])
  @@index([status])
  @@index([sourcePlanId])
}

model AccreditationPlanLine {
  id            Int                     @id @default(autoincrement())
  planId        Int
  coursId       Int
  moduleId      Int?
  elementId     Int?
  semestre      String?
  volumeHoraire Int?
  isMandatory   Boolean                 @default(true)
  originLineId  Int?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  cours         Cours                   @relation(fields: [coursId], references: [id])
  element       ElementModule?          @relation(fields: [elementId], references: [id])
  module        Module?                 @relation(fields: [moduleId], references: [id])
  originLine    AccreditationPlanLine?  @relation("AccreditationPlanLineOrigin", fields: [originLineId], references: [id])
  derivedLines  AccreditationPlanLine[] @relation("AccreditationPlanLineOrigin")
  plan          AccreditationPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, coursId])
  @@index([planId])
  @@index([coursId])
  @@index([moduleId])
  @@index([elementId])
  @@index([originLineId])
}

model ClassAccreditationAssignment {
  id           Int               @id @default(autoincrement())
  classId      Int
  academicYear String
  planId       Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  class        AcademicClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  plan         AccreditationPlan @relation(fields: [planId], references: [id])

  @@unique([classId, academicYear])
  @@index([classId])
  @@index([planId])
  @@index([academicYear])
}

