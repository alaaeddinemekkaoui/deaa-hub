generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  staff
  viewer
}

enum StudentCycle {
  prepa
  engineer
  veterinary
  master
  doctorate
}

enum Sex {
  male
  female
}

enum PrepaYear {
  prepa_1
  prepa_2
}

enum ElementType {
  CM
  TD
  TP
}

enum WorkflowStatus {
  pending
  in_progress
  completed
}

enum AccreditationPlanStatus {
  draft
  published
  archived
}

enum DiplomaStatus {
  retrieved
  not_retrieved
}

model User {
  id               Int            @id @default(autoincrement())
  fullName         String
  email            String         @unique
  passwordHash     String
  role             UserRole
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  activityLogs     ActivityLog[]
  assignedWorkflows WorkflowTask[]
}

model Department {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  filieres    Filiere[]
  teachers    Teacher[]

  @@index([name])
}

model Filiere {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  departmentId Int
  filiereType String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  students    Student[]
  teachers    Teacher[]
  classes     AcademicClass[]
  options     Option[]
  modules     Module[]
  accreditationPlans AccreditationPlan[]

  @@index([departmentId])
}

model Student {
  id               Int        @id @default(autoincrement())
  firstName        String?
  lastName         String?
  fullName         String
  sex              Sex
  cin              String     @unique
  codeMassar       String     @unique
  dateNaissance    DateTime
  email            String?    @unique
  telephone        String?
  cycle            StudentCycle
  prepaYear        PrepaYear?
  prepaTrack       String?
  entryLevel       Int?
  filiereId        Int?
  classId          Int?
  bacType          String?
  firstYearEntry   Int
  anneeAcademique  String
  dateInscription  DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  filiere          Filiere?   @relation(fields: [filiereId], references: [id], onDelete: SetNull)
  academicClass    AcademicClass? @relation(fields: [classId], references: [id], onDelete: SetNull)
  classHistory     StudentClassHistory[]
  observations     StudentObservation[]
  documents        Document[]
  workflows        WorkflowTask[]
  laureate         Laureate?

  @@index([codeMassar])
  @@index([filiereId])
  @@index([classId])
  @@index([cycle])
  @@index([sex])
  @@index([firstYearEntry])
}

model StudentObservation {
  id        Int      @id @default(autoincrement())
  studentId Int
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model StudentClassHistory {
  id             Int           @id @default(autoincrement())
  studentId      Int
  classId        Int
  academicYear   String
  studyYear      Int
  decisionStatus String?       @default("admis")
  createdAt      DateTime      @default(now())
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicClass  AcademicClass @relation(fields: [classId], references: [id], onDelete: Restrict)

  @@unique([studentId, academicYear])
  @@index([studentId])
  @@index([classId])
  @@index([academicYear])
}

model Teacher {
  id           Int          @id @default(autoincrement())
  firstName    String
  lastName     String
  cin          String?      @unique
  email        String?      @unique
  phoneNumber  String?
  dateInscription DateTime  @default(now())
  departmentId Int
  filiereId    Int?
  roleId       Int
  gradeId      Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  filiere      Filiere?     @relation(fields: [filiereId], references: [id], onDelete: SetNull)
  role         TeacherRole  @relation(fields: [roleId], references: [id], onDelete: Restrict)
  grade        TeacherGrade @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  taughtClasses TeacherClass[]
  taughtCours   CoursClass[]
  sessions      TimetableSession[]

  @@index([departmentId])
  @@index([filiereId])
  @@index([roleId])
  @@index([gradeId])
  @@index([lastName, firstName])
}

model TeacherRole {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]
}

model TeacherGrade {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]
}

model Cycle {
  id        Int             @id @default(autoincrement())
  name      String          @unique
  code      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  classes   AcademicClass[]
  accreditationPlans AccreditationPlan[]
}

model AcademicClass {
  id          Int      @id @default(autoincrement())
  name        String
  year        Int
  filiereId   Int?
  classType   String?
  cycleId     Int?
  option      String?
  optionId    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  filiere     Filiere?       @relation(fields: [filiereId], references: [id], onDelete: SetNull)
  academicOption Option?     @relation(fields: [optionId], references: [id], onDelete: SetNull)
  cycle       Cycle?         @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  students    Student[]
  teachers    TeacherClass[]
  studentHistory StudentClassHistory[]
  cours       CoursClass[]
  sessions    TimetableSession[]
  elements    ElementModule[]
  modules     ModuleClass[]
  accreditationAssignments ClassAccreditationAssignment[]

  @@index([year])
  @@index([filiereId])
  @@index([optionId])
  @@index([cycleId])
  @@unique([name, year])
}

model ModuleClass {
  moduleId  Int
  classId   Int
  module    Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  class     AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([moduleId, classId])
  @@index([moduleId])
  @@index([classId])
}

model TeacherClass {
  id        Int          @id @default(autoincrement())
  teacherId Int
  classId   Int
  createdAt DateTime     @default(now())
  teacher   Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class     AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
  @@index([teacherId])
  @@index([classId])
}

model Document {
  id            Int       @id @default(autoincrement())
  name          String
  mimeType      String
  path          String
  studentId     Int
  createdAt     DateTime  @default(now())
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  laureateProof Laureate[]

  @@index([studentId])
}

model WorkflowTask {
  id           Int             @id @default(autoincrement())
  title        String
  description  String?
  status       WorkflowStatus  @default(pending)
  assignedToId Int
  studentId    Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  assignedTo   User            @relation(fields: [assignedToId], references: [id], onDelete: Restrict)
  student      Student?        @relation(fields: [studentId], references: [id], onDelete: SetNull)
  timeline     WorkflowTimeline[]

  @@index([assignedToId])
  @@index([studentId])
}

model WorkflowTimeline {
  id          Int            @id @default(autoincrement())
  taskId       Int
  status       WorkflowStatus
  note         String?
  changedAt    DateTime      @default(now())
  task         WorkflowTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Room {
  id           Int                @id @default(autoincrement())
  name         String             @unique
  capacity     Int
  equipment    Json?
  availability Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  sessions     TimetableSession[]
}

model Laureate {
  id             Int           @id @default(autoincrement())
  studentId      Int           @unique
  graduationYear Int
  diplomaStatus  DiplomaStatus @default(not_retrieved)
  proofDocumentId Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  proofDocument  Document?     @relation(fields: [proofDocumentId], references: [id], onDelete: SetNull)

  @@index([graduationYear])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  metadata  Json?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Cours {
  id              Int          @id @default(autoincrement())
  name            String       @unique
  type            ElementType  @default(CM)
  elementModuleId Int?         @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  classes         CoursClass[]
  elementModule   ElementModule? @relation(fields: [elementModuleId], references: [id], onDelete: SetNull)
  accreditationLines AccreditationPlanLine[]

  @@index([name])
  @@index([elementModuleId])
}

model AccreditationPlan {
  id            Int                     @id @default(autoincrement())
  name          String
  academicYear  String
  levelYear     Int?
  filiereId     Int?
  optionId      Int?
  cycleId       Int?
  status        AccreditationPlanStatus @default(draft)
  sourcePlanId  Int?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  filiere       Filiere?                @relation(fields: [filiereId], references: [id], onDelete: SetNull)
  option        Option?                 @relation(fields: [optionId], references: [id], onDelete: SetNull)
  cycle         Cycle?                  @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  sourcePlan    AccreditationPlan?      @relation("AccreditationPlanSource", fields: [sourcePlanId], references: [id], onDelete: SetNull)
  derivedPlans  AccreditationPlan[]     @relation("AccreditationPlanSource")
  lines         AccreditationPlanLine[]
  classAssignments ClassAccreditationAssignment[]

  @@index([academicYear])
  @@index([filiereId])
  @@index([optionId])
  @@index([cycleId])
  @@index([status])
  @@index([sourcePlanId])
  @@unique([name, academicYear])
}

model AccreditationPlanLine {
  id            Int                @id @default(autoincrement())
  planId        Int
  coursId       Int
  moduleId      Int?
  elementId     Int?
  semestre      String?
  volumeHoraire Int?
  isMandatory   Boolean            @default(true)
  originLineId  Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  plan          AccreditationPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  cours         Cours              @relation(fields: [coursId], references: [id], onDelete: Restrict)
  module        Module?            @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  element       ElementModule?     @relation(fields: [elementId], references: [id], onDelete: SetNull)
  originLine    AccreditationPlanLine? @relation("AccreditationLineOrigin", fields: [originLineId], references: [id], onDelete: SetNull)
  derivedLines  AccreditationPlanLine[] @relation("AccreditationLineOrigin")

  @@index([planId])
  @@index([coursId])
  @@index([moduleId])
  @@index([elementId])
  @@index([originLineId])
  @@unique([planId, coursId])
}

model ClassAccreditationAssignment {
  id             Int               @id @default(autoincrement())
  classId        Int
  academicYear   String
  planId         Int
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  class          AcademicClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  plan           AccreditationPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@unique([classId, academicYear])
  @@index([classId])
  @@index([planId])
  @@index([academicYear])
}

// ─── Academic Structure ────────────────────────────────────────────────────────

model Option {
  id        Int             @id @default(autoincrement())
  name      String
  code      String?
  filiereId Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  filiere   Filiere         @relation(fields: [filiereId], references: [id], onDelete: Restrict)
  classes   AcademicClass[]
  modules   Module[]
  accreditationPlans AccreditationPlan[]

  @@unique([name, filiereId])
  @@index([filiereId])
}

model Module {
  id        Int             @id @default(autoincrement())
  name      String
  semestre  String?
  filiereId Int?
  optionId  Int?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  filiere   Filiere?        @relation(fields: [filiereId], references: [id], onDelete: SetNull)
  option    Option?         @relation(fields: [optionId], references: [id], onDelete: SetNull)
  elements  ElementModule[]
  classes   ModuleClass[]
  accreditationLines AccreditationPlanLine[]

  @@index([filiereId])
  @@index([optionId])
}

model ElementModule {
  id            Int                @id @default(autoincrement())
  name          String
  moduleId      Int
  classId       Int?
  volumeHoraire Int?
  type          ElementType        @default(CM)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  module        Module             @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  class         AcademicClass?     @relation(fields: [classId], references: [id], onDelete: SetNull)
  sessions      TimetableSession[]
  cours         Cours?
  accreditationLines AccreditationPlanLine[]

  @@index([moduleId])
  @@index([classId])
}

// ─── Timetable ─────────────────────────────────────────────────────────────────

model TimetableSession {
  id        Int           @id @default(autoincrement())
  elementId Int
  classId   Int
  teacherId Int?
  roomId    Int?
  dayOfWeek Int
  startTime String
  endTime   String
  weekStart DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  element   ElementModule @relation(fields: [elementId], references: [id], onDelete: Cascade)
  class     AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   Teacher?      @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  room      Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([classId])
  @@index([teacherId])
  @@index([roomId])
  @@index([elementId])
  @@index([dayOfWeek])
  @@index([weekStart])
}

model CoursClass {
  id         Int           @id @default(autoincrement())
  coursId    Int
  classId    Int
  teacherId  Int?
  groupLabel String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  cours      Cours         @relation(fields: [coursId], references: [id], onDelete: Cascade)
  class      AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher    Teacher?      @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([coursId, classId, teacherId])
  @@index([coursId])
  @@index([classId])
  @@index([coursId, classId])
  @@index([teacherId])
}
