  cours                  Cours?
  class                  AcademicClass?          @relation(fields: [classId], references: [id])
  module                 Module                  @relation(fields: [moduleId], references: [id])
  grades                 StudentGrade[]
  sessions               TimetableSession[]

  @@index([moduleId])
  @@index([classId])
}

model TimetableSession {
  id                  Int                     @id @default(autoincrement())
  elementId           Int
  classId             Int
  teacherId           Int?
  roomId              Int?
  dayOfWeek           Int
  startTime           String
  endTime             String
  weekStart           DateTime?
